 1 local AimingLogic = {}

 1 function AimingLogic.evaluate(snapshot)
 4     local nextAimState = false
 4     local shouldTriggerEvent = false
 4     local eventValue = nil
 4     local sleep = 250

 4     if snapshot.isLoggedIn and not snapshot.isPauseMenuActive then
 3         if snapshot.hasWeapon then
 2             nextAimState = snapshot.isControlPressed
 2             sleep = nextAimState and 0 or 50
           end

 3         if nextAimState ~= snapshot.lastAimState then
 1             shouldTriggerEvent = true
 1             eventValue = nextAimState
           end
 1     elseif snapshot.lastAimState then
 1         shouldTriggerEvent = true
 1         eventValue = false
       end

 4     return {
 4         nextAimState = nextAimState,
 4         shouldTriggerEvent = shouldTriggerEvent,
 4         eventValue = eventValue,
 4         sleep = sleep,
 4     }
   end

 1 QbWeaponsAimingLogic = AimingLogic

 1 return AimingLogic

